# Anthropic — paraphrase + theme tagging via Claude Haiku.
# Use the existing Kakashi Ventures project key. Set in Vercel project → Settings → Environment Variables.
ANTHROPIC_API_KEY=sk-ant-...

# Validator login — single shared password for v0.
# Auth header: Basic base64("validator:$VALIDATOR_PASSWORD")
VALIDATOR_PASSWORD=change-me-before-deploy

# Vercel KV — injected automatically when you attach a KV store to the project.
# Do not commit real values. Left here for documentation.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=

# Optional — overrides the daily cron schedule for manual /api/ingest calls.
# Bot identity sent to Finanzaonline. Identify honestly; do not spoof a browser.
INGEST_USER_AGENT=SASP-research/1.0 (+https://kakashi.ventures)
